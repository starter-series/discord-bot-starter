{
  "name": "discord-bot-starter",
  "version": "1.0.0",
  "description": "Production-ready Discord bot template with CI/CD and one-click deployment",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy-commands": "node scripts/deploy-commands.js",
    "lint": "eslint src/",
    "test": "jest --verbose --passWithNoTests",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
